# ── YYKANPAN Configuration ────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are used when unset.

# Server
# FUN_HOST=127.0.0.1
# FUN_PORT=5000
# FUN_DEBUG=true

# Cache TTLs (seconds)
# FUN_AK_CACHE_TTL=20
# FUN_STOCKS_CACHE_TTL=600
# FUN_52W_CACHE_TTL=43200
# FUN_HISTORY_CACHE_TTL=3600
# FUN_LIMIT_STATS_CACHE_TTL=300

# Retry
# FUN_MAX_RETRIES=2
# FUN_RETRY_BACKOFF=0.8

# Timeouts (seconds)
# FUN_SINA_KLINE_TIMEOUT=8
# FUN_SINA_QUOTE_TIMEOUT=10
# FUN_YAHOO_TIMEOUT=10
# FUN_IWENCAI_TIMEOUT=10
# FUN_NEWS_TIMEOUT=8

# Data source URLs
# FUN_SINA_KLINE_URL=http://money.finance.sina.com.cn/quotes_service/api/json_v2.php/CN_MarketData.getKLineData
# FUN_SINA_QUOTE_URL=https://hq.sinajs.cn/list=
# FUN_IWENCAI_URL=https://www.iwencai.com/unifiedwap/result

# Data parameters
# FUN_TRADING_DAYS=260
# FUN_YAHOO_PERIOD=2d

# Limits
# FUN_SENTIMENT_HISTORY_MAX=200
# FUN_NEWS_HEADLINE_LIMIT=5
# FUN_NEWS_SUMMARY_MAX_LEN=180
# FUN_BRIEF_HEADLINES=3
# FUN_HISTORY_DEFAULT_DAYS=20
# FUN_HISTORY_MAX_DAYS=60

# Analysis thresholds
# FUN_PROFIT_RATE_GOOD=60
# FUN_PROFIT_RATE_NEUTRAL=40
# FUN_MAINLINE_CONC=0.2
# FUN_MAINLINE_STRENGTH=2.0
